FLASK_ENV=development
SECRET_KEY=change-me-to-a-secure-random-string

# --- Supabase PostgreSQL (production / optional local testing) ---
# Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI
# Use "Session pooler" for Flask on Render (port 6543).
#
# Example (pooler):
# DATABASE_URL=postgresql://postgres.abcdefghijklmnop:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
#
# Leave empty for local development (uses backend/instance/sansu_lms.db)
DATABASE_URL=

# Frontend origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,https://aura-learning-management-system.vercel.app
