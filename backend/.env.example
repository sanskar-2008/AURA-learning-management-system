FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-secure-random-string

# Local development: leave empty to use SQLite at backend/instance/sansu_lms.db
# Production (Supabase): paste the PostgreSQL connection string from Supabase
# Project Settings -> Database -> Connection string -> URI
# Example:
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Comma-separated frontend origins (include your Vercel URL in production)
CORS_ORIGINS=http://localhost:5173,https://aura-learning-management-system.vercel.app
